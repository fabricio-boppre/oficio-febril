---
import { css } from "@styled-system/css"
import { flex } from "@styled-system/patterns"
import { Image } from "astro:assets"
const { content, route } = Astro.props
---

{
  content.length > 0 ? (
    <div
      class={flex({
        gap: ["30px", undefined, "40px"],
        flexWrap: "wrap",
        justifyContent: "center",
      })}
    >
      {content.map((item: any) => {
        return (
          <a
            class={css({
              display: "block",
              w: "200px",
            })}
            href={"/" + route + "/" + item.id}
          >
            <Image src={item.data.imagem_para_indice} alt={item.data.titulo} />
            <span class={css({ textStyle: "spanText" })}>
              {item.data.titulo}
            </span>
          </a>
        )
      })}
    </div>
  ) : (
    <p>Não há nenhum item para ser exibido aqui.</p>
  )
}
